{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "syncpack": {
    "config": ["syncpack.config.{mjs,cjs,js}"]
  },
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.{sh,mjs,ts}",
        "*.mts",
        "cz.config.js",
        ".changeset/*.md"
      ],
      "project": ["*.{ts,mts,js,mjs}"],
      "ignoreDependencies": []
    },
    "packages/react": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/dom-utils/**"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/preact": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/dom-utils/**"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/vue": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/dom-utils/**"],
      "vitest": {
        "config": ["vitest.config.mts"]
      }
    },
    "packages/solid": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/dom-utils/**"],
      "vitest": {
        "config": ["vitest.config.mts"]
      },
      "ignoreDependencies": ["@babel/preset-typescript", "babel-preset-solid"]
    },
    "packages/svelte": {
      "project": ["src/**/*.{ts,svelte,svelte.ts}"],
      "ignore": ["src/dom-utils/**"],
      "vitest": {
        "config": ["vitest.config.mts"]
      },
      "ignoreDependencies": ["@real-router/browser-plugin"]
    },
    "packages/dom-utils": {
      "entry": ["tests/**/*.{ts,tsx}"],
      "project": ["tests/**/*.ts"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/browser-env": {
      "entry": ["tests/**/*.{ts,tsx}"],
      "project": ["tests/**/*.ts"],
      "ignoreDependencies": ["type-guards"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/browser-plugin": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/browser-env/**"],
      "ignoreDependencies": ["@real-router/types"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/hash-plugin": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/browser-env/**"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/navigation-plugin": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/browser-env/**"],
      "ignoreDependencies": ["type-guards", "@real-router/types"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/memory-plugin": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@real-router/types"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/persistent-params-plugin": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@real-router/types"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/ssr-data-plugin": {
      "project": ["src/**/*.ts"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      }
    },
    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      },
      "stryker": {
        "config": ["stryker.config.mjs"]
      }
    }
  },
  "ignoreWorkspaces": ["examples/**", "benchmarks"],
  "ignore": ["benchmarks/**"],
  "ignoreDependencies": ["@stryker-mutator/api", "jsdom"],
  "ignoreBinaries": ["tree", "tsx", "open", "perl"],
  "ignoreExportsUsedInFile": true
}
