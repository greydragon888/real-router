{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "syncpack": {
    "config": ["syncpack.config.{mjs,cjs,js}"]
  },
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.{sh,mjs,ts}",
        "*.mts",
        "cz.config.js",
        ".changeset/*.md"
      ],
      "project": ["*.{ts,mts,js,mjs}"],
      "ignoreDependencies": ["terser", "fast-check"]
    },
    "packages/router-benchmarks": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/solid": {
      "project": ["src/**/*.{ts,tsx}"],
      "vitest": {
        "config": ["vitest.config.mts"]
      },
      "ignoreDependencies": ["@babel/preset-typescript", "babel-preset-solid"]
    },
    "packages/vue": {
      "project": ["src/**/*.ts"],
      "vitest": {
        "config": ["vitest.config.mts"]
      }
    },
    "packages/svelte": {
      "project": ["src/**/*.{ts,svelte,svelte.ts}"],
      "vitest": {
        "config": ["vitest.config.mts"]
      },
      "ignoreDependencies": ["@real-router/browser-plugin"]
    },
    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"],
      "vitest": {
        "config": ["vitest.config.mts", "vitest.config.*.mts"]
      },
      "stryker": {
        "config": ["stryker.config.mjs"]
      }
    }
  },
  "ignoreWorkspaces": ["examples/**"],
  "ignore": [],
  "ignoreDependencies": ["@stryker-mutator/api", "jsdom"],
  "ignoreBinaries": ["tree", "tsx", "open", "ps", "awk"],
  "ignoreExportsUsedInFile": true
}
