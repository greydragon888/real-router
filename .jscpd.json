{
  "threshold": 2,
  "minLines": 5,
  "minTokens": 70,
  "mode": "weak",
  "reporters": ["console"],
  "ignore": [
    "packages/preact/src/**",
    "packages/hash-plugin/src/**",
    "packages/*/src/dom-utils/**",
    "packages/*/src/browser-env/**",
    "packages/*/src/shared-ssr/**",
    "packages/*/src/**/*.react-server.ts",
    "packages/react/src/legacy.ts",
    "packages/react/src/legacy.ssr.ts",
    "packages/react/src/ink.ts",
    "packages/validation-plugin/src/type-guards/**",
    "shared/browser-env/state-guard.ts",
    "**/*.d.ts"
  ],
  "format": ["typescript", "tsx", "svelte"],
  "absolute": false,
  "gitignore": true
}
