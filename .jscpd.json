{
  "$schema": "https://json.schemastore.org/jscpd.json",
  "threshold": 2,
  "minLines": 5,
  "minTokens": 70,
  "skipComments": true,
  "reporters": ["console"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.stryker-tmp/**",
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.bench.ts",
    "**/*.spec.ts",
    "**/*.properties.ts",
    "benchmarks/**",
    "packages/preact/src/**",
    "packages/hash-plugin/src/**",
    "packages/*/src/dom-utils/**",
    "packages/*/src/browser-env/**",
    "packages/*/src/shared-ssr/**",
    "packages/*/src/**/*.react-server.ts",
    "packages/react/src/legacy.ts",
    "packages/react/src/legacy.ssr.ts",
    "packages/react/src/ink.ts"
  ],
  "format": ["typescript", "tsx", "svelte"],
  "absolute": false,
  "gitignore": true
}
