{
  "$schema": "./node_modules/turbo/schema.json",
  "futureFlags": {
    "globalConfiguration": true,
    "errorsOnlyShowHash": true,
    "affectedUsingTaskInputs": true,
    "watchUsingTaskInputs": true,
    "filterUsingTasks": true
  },
  "global": {
    "concurrency": "4",
    "passThroughEnv": ["CI", "GITHUB_ACTIONS"],
    "inputs": [
      "tsconfig.json",
      "prettier.config.*",
      "tsdown.base.*",
      "eslint.config.*",
      "vitest.config.*"
    ],
    "env": ["BENCH_ROUTER", "BENCH_NO_VALIDATE", "BENCH_SECTIONS"]
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build", "test", "test:properties", "test:stress"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**/*.{ts,tsx,vue,svelte}",
        "tsdown.config.*",
        "tsconfig.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputLogs": "errors-only",
      "cache": true
    },
    "build:dist-only": {
      "dependsOn": ["^build:dist-only"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**/*.{ts,tsx,vue,svelte}",
        "tsdown.config.*",
        "tsconfig.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputLogs": "errors-only",
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": [
        "src/**/*.{ts,tsx,vue,svelte}",
        "e2e/**/*.{ts,tsx}",
        "playwright.config.*",
        "index.html",
        "vite.config.*",
        "package.json"
      ],
      "outputLogs": "errors-only",
      "cache": true
    },
    "test:stress": {
      "dependsOn": ["^build", "test:properties", "test", "lint", "type-check"],
      "outputs": [],
      "inputs": [
        "tests/stress/**/*.{ts,tsx}",
        "vitest.config.stress.*",
        "!**/node_modules/**"
      ],
      "outputLogs": "errors-only",
      "cache": true
    },
    "test:properties": {
      "dependsOn": ["^build", "test", "lint", "type-check"],
      "outputs": [],
      "inputs": [
        "tests/property/**/*.{ts,tsx}",
        "vitest.config.properties.*",
        "!**/node_modules/**"
      ],
      "outputLogs": "errors-only",
      "cache": true
    },
    "test": {
      "dependsOn": ["^build", "lint", "type-check"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.{ts,tsx}",
        "tests/**/*.{ts,tsx}",
        "vitest.config.*",
        "**/*.test.{ts,tsx}",
        "**/*.spec.{ts,tsx}",
        "!**/node_modules/**"
      ],
      "env": ["NODE_ENV"],
      "passThroughEnv": ["CI"],
      "outputLogs": "errors-only",
      "cache": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": [
        "**/*.{ts,tsx,js,jsx}",
        "!dist/**",
        "!coverage/**",
        "!**/node_modules/**",
        "eslint.config.*"
      ],
      "outputLogs": "errors-only",
      "cache": true
    },
    "type-check": {
      "dependsOn": ["^build:dist-only"],
      "outputs": [],
      "inputs": [
        "**/*.{ts,tsx,vue,svelte}",
        "!dist/**",
        "!**/node_modules/**",
        "tsconfig.json",
        "**/tsconfig.json"
      ],
      "outputLogs": "errors-only",
      "cache": true
    },
    "lint:package": {
      "dependsOn": ["build:dist-only"],
      "outputs": [],
      "inputs": ["dist/**", "package.json"],
      "cache": true
    },
    "lint:types": {
      "dependsOn": ["build:dist-only"],
      "outputs": [],
      "inputs": ["dist/**", "package.json"],
      "cache": true
    }
  }
}
