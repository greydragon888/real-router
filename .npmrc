# pnpm 10 settings
update-notifier=false
save-exact=true
git-tag-version=true
loglevel=error

# pnpm specific (strict mode for early peer deps detection)
auto-install-peers=true
strict-peer-dependencies=true

# Security: only install packages older than 1 day (protection from compromised packages)
minimum-release-age=1440
minimum-release-age-exclude[]=brace-expansion
# TODO: REMOVE THIS EXCLUSION! eslint-plugin-unicorn@64.0.0 was published <24h ago (2026-03-28), won't pass minimum-release-age check until 2026-03-29
minimum-release-age-exclude[]=eslint-plugin-unicorn

# Security: strict build scripts verification (lifecycle scripts disabled by default in pnpm 10)
strict-dep-builds=true

# Auto-cleanup unused catalog entries
cleanup-unused-catalogs=true

script-shell=bash
