{
  "name": "real-router",
  "version": "0.48.0",
  "type": "module",
  "description": "A real router. Just routing, nothing else.",
  "scripts": {
    "build": "turbo run build",
    "build:verbose": "turbo run build --output-logs=full",
    "bundle": "turbo run bundle",
    "test": "turbo run test",
    "test:verbose": "turbo run test --output-logs=full",
    "test:stress": "turbo run test:stress",
    "test:properties": "turbo run test:properties",
    "test:coverage": "turbo run test -- --coverage",
    "test:agent": "turbo run test -- --reporter=agent",
    "test:leaks": "turbo run test -- --detect-async-leaks",
    "test:changed": "turbo run test -- --coverage.changed",
    "test:mutation": "stryker run",
    "lint": "turbo run lint",
    "lint:types": "turbo run lint:types",
    "lint:package": "turbo run lint:package",
    "lint:unused": "knip",
    "lint:duplicates": "jscpd packages/*/src/",
    "lint:e2e": "bash scripts/check-e2e-specs.sh",
    "lint:deps": "syncpack lint",
    "lint:deps:fix": "syncpack fix && pnpm dedupe && pnpm install",
    "lint:dedupe": "pnpm dedupe --check",
    "type-check": "turbo run type-check",
    "sonar": "dotenv -- sonar -Dsonar.login=$SONAR_TOKEN",
    "sonar:local": "pnpm type-check && pnpm test:coverage && pnpm sonar",
    "packages-structure": "find packages/*/src -type f -name \"*.ts*\" -print | tree --fromfile",
    "prepare": "husky || true",
    "verify:examples": "pnpm -r --filter './examples/*/*' --workspace-concurrency=4 run build",
    "size": "size-limit",
    "commit": "czg",
    "changeset": "changeset",
    "version": "changeset version && node .changeset/cap-major-bumps.mjs && node .changeset/sync-version.mjs && node .changeset/aggregate-changelog.mjs",
    "release": "pnpm build && changeset publish",
    "danger:local": "danger local --dangerfile dangerfile.ts"
  },
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "keywords": [
    "router",
    "routing",
    "reactive",
    "universal",
    "isomorphic",
    "framework-agnostic"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "homepage": "https://github.com/greydragon888/real-router#readme",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@codspeed/vitest-plugin": "5.2.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint-react/eslint-plugin": "4.2.1",
    "@eslint/js": "10.0.1",
    "@fast-check/vitest": "0.4.0",
    "@size-limit/esbuild": "12.0.1",
    "@size-limit/preset-small-lib": "12.0.1",
    "@sonar/scan": "4.3.5",
    "@stryker-mutator/core": "9.6.0",
    "@stryker-mutator/typescript-checker": "9.6.0",
    "@stryker-mutator/vitest-runner": "9.6.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.13",
    "@vitest/ui": "4.1.0",
    "czg": "1.12.0",
    "danger": "13.0.7",
    "dotenv-cli": "11.0.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-turbo": "2.9.5",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-jsx": "4.2.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unicorn": "64.0.0",
    "fast-check": "4.6.0",
    "husky": "9.1.7",
    "jscpd": "4.0.8",
    "knip": "6.3.0",
    "mitata": "1.0.34",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "size-limit": "12.0.1",
    "syncpack": "14.3.0",
    "tsdown": "0.21.7",
    "turbo": "2.9.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild",
      "fsevents",
      "lmdb",
      "msgpackr-extract",
      "unrs-resolver",
      "vue-demi"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "6"
      }
    },
    "overrides": {
      "@types/node": "$@types/node",
      "@isaacs/brace-expansion": "5.0.1",
      "axios": ">=1.15.0",
      "follow-redirects": ">=1.16.0",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "minimatch@3": "~3.1.4",
      "minimatch@9": "~9.0.7",
      "minimatch@10": "~10.2.3",
      "ajv@6": "~6.14.0",
      "ajv@8": "~8.18.0",
      "underscore": ">=1.13.8",
      "http-proxy-agent": "7.0.2",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.2",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@5": "5.0.5",
      "node-forge": ">=1.4.0",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "yaml@1": "1.10.3",
      "yaml@2": "2.8.3",
      "@typescript-eslint/eslint-plugin": "8.57.1",
      "@typescript-eslint/parser": "8.57.1",
      "smol-toml": ">=1.6.1",
      "defu": ">=6.1.5"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
