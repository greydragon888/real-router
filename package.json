{
  "name": "real-router",
  "version": "0.38.0",
  "type": "module",
  "description": "A real router. Just routing, nothing else.",
  "scripts": {
    "build": "turbo run build",
    "build:verbose": "turbo run build --output-logs=full",
    "test": "turbo run test",
    "test:verbose": "turbo run test --output-logs=full",
    "test:stress": "turbo run test:stress",
    "test:properties": "turbo run test:properties",
    "test:coverage": "turbo run test -- --coverage",
    "test:agent": "turbo run test -- --reporter=agent",
    "test:fast": "turbo run test -- --tags-filter=\"!slow\"",
    "test:leaks": "turbo run test -- --detect-async-leaks",
    "test:changed": "turbo run test -- --coverage.changed",
    "test:mutation": "stryker run",
    "lint": "turbo run lint",
    "lint:types": "turbo run lint:types",
    "lint:package": "turbo run lint:package",
    "lint:unused": "knip",
    "lint:duplicates": "jscpd packages/*/src/",
    "lint:e2e": "bash scripts/check-e2e-specs.sh",
    "lint:deps": "syncpack lint",
    "lint:deps:fix": "syncpack fix && pnpm dedupe && pnpm install",
    "lint:dedupe": "pnpm dedupe --check",
    "validate:pre-push": "turbo run build lint:package lint:types",
    "type-check": "turbo run type-check",
    "sonar": "dotenv -- sonar -Dsonar.login=$SONAR_TOKEN",
    "sonar:local": "pnpm type-check && pnpm test:coverage && pnpm sonar",
    "packages-structure": "find packages/*/src -type f -name \"*.ts*\" -print | tree --fromfile",
    "prepare": "husky || true",
    "size": "size-limit",
    "commit": "czg",
    "changeset": "changeset",
    "version": "changeset version && node .changeset/sync-version.mjs && node .changeset/aggregate-changelog.mjs",
    "release": "pnpm build && changeset publish",
    "danger:local": "danger local --dangerfile dangerfile.ts"
  },
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "keywords": [
    "router",
    "routing",
    "reactive",
    "universal",
    "isomorphic",
    "framework-agnostic"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "homepage": "https://github.com/greydragon888/real-router#readme",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@codspeed/vitest-plugin": "5.0.1",
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@eslint-react/eslint-plugin": "3.0.0",
    "@eslint/js": "10.0.1",
    "@fast-check/vitest": "0.3.0",
    "@size-limit/esbuild": "12.0.0",
    "@size-limit/preset-small-lib": "12.0.0",
    "@sonar/scan": "4.3.4",
    "@stryker-mutator/core": "9.6.0",
    "@stryker-mutator/typescript-checker": "9.6.0",
    "@stryker-mutator/vitest-runner": "9.6.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.12",
    "@vitest/ui": "4.1.0",
    "czg": "1.12.0",
    "danger": "13.0.7",
    "dotenv-cli": "11.0.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-turbo": "2.8.17",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-testing-library": "7.16.1",
    "eslint-plugin-unicorn": "63.0.0",
    "fast-check": "4.6.0",
    "husky": "9.1.7",
    "jscpd": "4.0.8",
    "knip": "5.86.0",
    "mitata": "1.0.34",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "syncpack": "14.2.0",
    "terser": "5.46.0",
    "tsup": "8.5.1",
    "turbo": "2.8.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "fsevents",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/node": "$@types/node",
      "@isaacs/brace-expansion": "5.0.1",
      "axios": ">=1.13.5",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "minimatch@3": "~3.1.4",
      "minimatch@9": "~9.0.7",
      "minimatch@10": "~10.2.3",
      "ajv@6": "~6.14.0",
      "ajv@8": "~8.18.0",
      "underscore": ">=1.13.8",
      "http-proxy-agent": "7.0.2",
      "undici": ">=7.24.0"
    }
  },
  "packageManager": "pnpm@10.24.0"
}
