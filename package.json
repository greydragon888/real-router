{
  "name": "real-router",
  "version": "0.81.0",
  "type": "module",
  "description": "A real router. Just routing, nothing else.",
  "scripts": {
    "build": "turbo run build",
    "build:verbose": "turbo run build --output-logs=full",
    "bundle": "turbo run bundle",
    "test": "turbo run test",
    "test:verbose": "turbo run test --output-logs=full",
    "test:stress": "turbo run test:stress --concurrency=1 --filter='!./examples/**'",
    "test:properties": "turbo run test:properties",
    "test:agent": "turbo run test -- --reporter=agent",
    "test:leaks": "turbo run test -- --detect-async-leaks",
    "test:changed": "turbo run test -- --coverage.changed",
    "mutation:analyze": "node scripts/mutation-analyze.mjs",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:types": "turbo run lint:types",
    "lint:package": "turbo run lint:package",
    "lint:unused": "knip",
    "lint:duplicates": "jscpd packages/*/src/ shared/ --no-tips",
    "lint:duplicates:sarif": "jscpd packages/*/src/ shared/ --no-tips -t 100 -r sarif -o jscpd-report",
    "lint:e2e": "bash scripts/check-e2e-specs.sh",
    "lint:bench-apps": "node benchmarks/cross-router/harness/lint-spec-parity.mjs",
    "lint:coverage-scope": "node scripts/check-coverage-scope.mjs",
    "lint:audit": "bash scripts/check-deps-audit.sh",
    "lint:security": "bash scripts/check-semgrep.sh",
    "lint:deps": "syncpack lint",
    "lint:deps:fix": "syncpack fix && pnpm dedupe && pnpm install",
    "lint:dedupe": "pnpm dedupe --check",
    "lint:changeset": "node .changeset/check-changeset.mjs",
    "resolve:dependabot": "bash scripts/resolve-dependabot.sh",
    "type-check": "turbo run type-check",
    "sonar": "dotenv -- sonar-scanner-npm -Dsonar.login=$SONAR_TOKEN",
    "sonar:local": "bash scripts/sonar-local.sh",
    "packages-structure": "find packages/*/src -type f -name \"*.ts*\" -print | tree --fromfile",
    "prepare": "husky || true",
    "verify:examples": "pnpm -r --filter './examples/*/*' --workspace-concurrency=4 run build",
    "size": "size-limit",
    "commit": "czg",
    "changeset": "changeset",
    "version": "changeset version && node .changeset/cap-major-bumps.mjs && node .changeset/sync-version.mjs && node .changeset/aggregate-changelog.mjs",
    "release": "pnpm build && changeset publish",
    "danger:local": "danger local --dangerfile dangerfile.ts"
  },
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "keywords": [
    "router",
    "routing",
    "reactive",
    "universal",
    "isomorphic",
    "framework-agnostic"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "homepage": "https://github.com/greydragon888/real-router#readme",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@codspeed/tinybench-plugin": "5.7.1",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint-react/eslint-plugin": "5.10.0",
    "@eslint/js": "10.0.1",
    "@fast-check/vitest": "0.4.1",
    "@size-limit/esbuild": "12.1.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@sonar/scan": "5.0.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.22",
    "@vitest/ui": "4.1.10",
    "czg": "1.13.1",
    "danger": "13.0.10",
    "dotenv-cli": "11.0.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-turbo": "2.10.2",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.0",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unicorn": "72.0.0",
    "fast-check": "4.9.0",
    "husky": "9.1.7",
    "jscpd": "5.0.9",
    "jsdom": "29.1.1",
    "knip": "6.27.0",
    "prettier": "3.9.4",
    "publint": "0.3.21",
    "size-limit": "12.1.0",
    "syncpack": "15.3.1",
    "tinybench": "6.0.2",
    "tsdown": "0.22.12",
    "tsx": "4.23.1",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
