#!/bin/sh

# Pre-push hook: artifact validation before pushing
#
# - lint:changeset: Validate pending changeset files (fast fail-fast, runs
#                   first; no files → no-op)
# - lint:duplicates: Copy-paste detection (jscpd)
# - build: Final build to ensure compilation
# - test:stress: Heap/timing stress suites, isolated at --concurrency=1 so
#                heap measurements are free of build contention (#1423)
# - lint:types: Validate TypeScript types in dist (arethetypeswrong)
# - lint:package: Validate package.json exports (publint)
# - lint:unused: Dead code detection (knip)
# - lint:deps: Dependency version consistency (syncpack)
# - lint:audit: Vulnerability scan (osv-scanner, mirrors GHSA database
#               used by GitHub Dependency Review; non-blocking if
#               osv-scanner is not installed locally)
# - lint:security: Diff-aware SAST (semgrep, fast local complement to cloud
#                  CodeQL; only NEW findings on the branch; non-blocking if
#                  semgrep is not installed locally)

set -e

echo "🚀 Running pre-push checks..."

# Validate pending changeset files first — cheap (~10ms) static check, so it
# fails fast before the expensive build. No-op when .changeset/ holds no
# changesets (WIP/infra push).
echo "📝 Validating changesets..."
pnpm lint:changeset

# Check for code duplication
echo "📋 Checking for code duplication..."
pnpm lint:duplicates

# Build packages and validate published artifacts
echo "📦 Building packages..."
pnpm turbo run build lint:package lint:types --filter='!./examples/**'

# Heap/timing stress suites — run isolated at --concurrency=1 (they were
# dropped from build.dependsOn in #1423). Under the concurrent build, up to 4
# heap-sensitive suites ran in parallel and their heapUsed thresholds flaked
# from GC/CPU contention; serialized they measure clean. This is stress's only
# gate — CI/post-merge exclude it by design (see IMPLEMENTATION_NOTES).
echo "🧪 Running stress tests (isolated)..."
pnpm test:stress

# Check for unused code
echo "🧹 Checking for unused code..."
pnpm lint:unused

# Check dependency version consistency
echo "🔗 Checking dependency versions..."
pnpm lint:deps

# Vulnerability scan against GHSA database
echo "🔒 Auditing dependencies for known vulnerabilities..."
pnpm lint:audit

# Diff-aware SAST on the pushed source (fast local complement to cloud CodeQL)
echo "🔎 Running SAST diff scan (semgrep)..."
pnpm lint:security

echo "✅ All pre-push checks passed! Pushing to remote..."
