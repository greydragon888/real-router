#!/bin/sh

# Exit on any error
set -e

echo "🔍 Running pre-commit checks..."

# Auto-deduplicate lockfile if it's being committed.
# pnpm add/update don't dedupe automatically (pnpm/pnpm#7258),
# so we do it here to keep the lockfile clean.
if git diff --cached --name-only | grep -q 'pnpm-lock.yaml'; then
  echo "🔗 Auto-deduplicating lockfile..."
  pnpm dedupe
  git add pnpm-lock.yaml
fi

# Check dependency version consistency across workspace packages (~1s).
# Catches sub-package version drift at commit time instead of waiting for
# pre-push. Pure static check (no install), so it's cheap enough to run
# unconditionally.
echo "🔗 Checking dependency versions..."
pnpm lint:deps

# Coverage-scope drift guard — keeps codecov.yml components + Sonar coverage
# exclusions in sync with the package set (#732). Cheap static check, so it
# runs before the expensive turbo test pipeline (fail-fast).
echo "📊 Checking coverage scope..."
pnpm lint:coverage-scope

# Run type checking, linting, and tests via turbo pipeline
# (turbo caching makes lint-staged redundant)
echo "🧪 Running tests (includes type-check and lint via turbo)..."
pnpm turbo run test --filter='!./examples/**'

# Check that e2e directories have specs
# Cheap static check (find + wc) — catches forgotten e2e/ during scaffolding.
# lint:duplicates (jscpd) and lint:unused (knip) live in pre-push only —
# their analysis depends on the full tree, not on the current commit's diff.
echo "🎭 Checking e2e specs..."
pnpm lint:e2e

echo "✅ Pre-commit checks passed!"
