{
  "name": "router-benchmarks",
  "version": "0.3.75",
  "private": true,
  "description": "Benchmark tests for @real-router/core",
  "scripts": {
    "prebench": "pnpm --filter @real-router/core... build",
    "bench": "BENCH_ROUTER=real-router NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx core/index.ts",
    "bench:router5": "BENCH_ROUTER=router5 NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx core/index.ts",
    "bench:router6": "BENCH_ROUTER=router6 NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx core/index.ts",
    "bench:current": "pnpm prebench && BENCH_ROUTER=real-router NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx core/index.ts",
    "bench:vs-tanstack": "node vs-tanstack/run.mjs",
    "bench:vs-tanstack:real-router": "node vs-tanstack/run.mjs client-nav real-router react speed",
    "bench:vs-tanstack:tanstack": "node vs-tanstack/run.mjs client-nav tanstack react speed",
    "bench:bundle-size": "node vs-tanstack/bundle-size/build-all.mjs",
    "bench:cross-router": "node cross-router/run.mjs",
    "cpu": "ps -Ao %cpu,comm -r | awk '$1 > 10 && !/webstorm/ && !/claude/ && !/WindowServer/ {print $2 \" (\" $1 \"%)\"}' | head -10",
    "bench:type-check": "tsc --noEmit && tsc --noEmit -p vs-tanstack/tsconfig.solid.json",
    "bench:lint": "eslint --cache core/ vs-tanstack/ --fix --max-warnings 0"
  },
  "dependencies": {
    "@angular/common": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/platform-browser": "22.0.5",
    "@angular/router": "22.0.5",
    "@mateothegreat/svelte5-router": "2.16.19",
    "@nanostores/react": "0.8.4",
    "@nanostores/solid": "1.1.1",
    "@nanostores/vue": "1.1.0",
    "@real-router/angular": "workspace:^",
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/lifecycle-plugin": "workspace:^",
    "@real-router/memory-plugin": "workspace:^",
    "@real-router/react": "workspace:^",
    "@real-router/search-schema-plugin": "workspace:^",
    "@real-router/solid": "workspace:^",
    "@real-router/svelte": "workspace:^",
    "@real-router/types": "workspace:^",
    "@real-router/vue": "workspace:^",
    "@solidjs/router": "0.16.1",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/solid-router": "1.170.15",
    "@tanstack/vue-router": "1.170.15",
    "mitata": "1.0.34",
    "nanostores": "0.11.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1",
    "router5": "8.0.1",
    "router6": "1.0.2",
    "solid-js": "1.9.13",
    "sv-router": "0.17.0",
    "svelte": "5.56.4",
    "vue": "3.5.38",
    "vue-router": "4.6.4",
    "wouter": "3.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.2",
    "@angular/build": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tanstack/router-core": "1.171.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "vite": "7.3.5",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.9"
  }
}
