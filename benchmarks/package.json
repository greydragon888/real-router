{
  "name": "router-benchmarks",
  "version": "0.3.96",
  "private": true,
  "description": "Benchmark tests for @real-router/core",
  "scripts": {
    "bench:cross-router": "node cross-router/run.mjs",
    "cpu": "ps -Ao %cpu,comm -r | awk '$1 > 10 && !/webstorm/ && !/claude/ && !/WindowServer/ {print $2 \" (\" $1 \"%)\"}' | head -10",
    "prebuild:adapter": "pnpm -w exec turbo run bundle --filter=@real-router/angular --filter=@real-router/memory-plugin --output-logs=errors-only && vite build --config adapter-bench/vite/react.config.mts && vite build --config adapter-bench/vite/preact.config.mts && vite build --config adapter-bench/vite/vue.config.mts && vite build --config adapter-bench/vite/solid.config.mts && vite build --config adapter-bench/vite/svelte.config.mts && vite build --config adapter-bench/vite/angular.config.mts",
    "bench:adapter": "pnpm run prebuild:adapter && node --expose-gc --import tsx adapter-bench/codspeed.mts"
  },
  "dependencies": {
    "@angular/common": "~22.0.6",
    "@angular/core": "~22.0.6",
    "@angular/platform-browser": "~22.0.6",
    "@angular/router": "~22.0.6",
    "@mateothegreat/svelte5-router": "~2.16.19",
    "@nanostores/react": "0.8.4",
    "@nanostores/solid": "1.1.1",
    "@nanostores/vue": "1.1.0",
    "@real-router/angular": "workspace:^",
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/lifecycle-plugin": "workspace:^",
    "@real-router/memory-plugin": "workspace:^",
    "@real-router/preact": "workspace:^",
    "@real-router/react": "workspace:^",
    "@real-router/search-schema-plugin": "workspace:^",
    "@real-router/solid": "workspace:^",
    "@real-router/svelte": "workspace:^",
    "@real-router/types": "workspace:^",
    "@real-router/vue": "workspace:^",
    "@solidjs/router": "~0.16.1",
    "@tanstack/react-router": "~1.170.17",
    "@tanstack/solid-router": "~1.170.17",
    "@tanstack/vue-router": "~1.170.16",
    "mitata": "1.0.34",
    "nanostores": "0.11.4",
    "preact": "~10.29.7",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "react-router": "~8.2.0",
    "solid-js": "~1.9.14",
    "sv-router": "~0.17.0",
    "svelte": "~5.56.4",
    "vue": "~3.5.39",
    "vue-router": "~5.1.0",
    "wouter": "~3.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.2",
    "@angular/build": "~22.0.6",
    "@angular/compiler": "~22.0.6",
    "@angular/compiler-cli": "~22.0.6",
    "@real-router/persistent-params-plugin": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "vite": "7.3.6",
    "vite-plugin-solid": "2.11.12"
  }
}
