{
  "extends": "../../../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "incremental": false
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
