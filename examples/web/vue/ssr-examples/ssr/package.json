{
  "name": "ssr-vue-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssr-vue-example",
    "dev": "tsx server/dev.ts",
    "build:app": "vue-tsc -b && vite build --outDir dist/client && vite build --ssr src/entry-server.ts --outDir dist/server",
    "preview": "NODE_ENV=production tsx server/index.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "@real-router/vue": "workspace:^",
    "express": "5.1.0",
    "vue": "3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/express": "5.0.6",
    "@types/node": "25.8.0",
    "@vitejs/plugin-vue": "6.0.5",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "7.3.2",
    "vue-tsc": "3.2.6"
  }
}
