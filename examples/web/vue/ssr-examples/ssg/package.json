{
  "name": "ssg-vue-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssg-vue-example",
    "dev": "vite",
    "build:app": "vue-tsc -b && vite build && vite build --ssr src/entry-server.ts --outDir dist/server && tsx scripts/ssg-build.ts",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "@real-router/ssr-utils": "workspace:^",
    "@real-router/vue": "workspace:^",
    "vue": "~3.5.39"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "6.0.7",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vue-tsc": "3.3.5"
  }
}
