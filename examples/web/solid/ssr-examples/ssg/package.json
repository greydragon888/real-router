{
  "name": "ssg-solid-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssg-solid-example",
    "dev": "vite",
    "build:app": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && tsx scripts/ssg-build.ts",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/solid": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "solid-js": "~1.9.14"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.13.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vite-plugin-solid": "2.11.12"
  }
}
