{
  "name": "ssg-preact-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssg-preact-example",
    "dev": "vite",
    "build:app": "vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && tsx scripts/ssg-build.ts",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/preact": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "preact": "~10.29.7",
    "preact-render-to-string": "~6.7.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@preact/preset-vite": "2.10.5",
    "@types/node": "24.13.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "7.3.6"
  }
}
