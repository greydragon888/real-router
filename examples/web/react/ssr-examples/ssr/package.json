{
  "name": "ssr-react-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssr-react-example",
    "dev": "tsx server/dev.ts",
    "build:app": "vite build --outDir dist/client && vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "NODE_ENV=production tsx server/index.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/react": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "express": "5.1.0",
    "react": "~19.2.7",
    "react-dom": "~19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "7.3.6"
  }
}
