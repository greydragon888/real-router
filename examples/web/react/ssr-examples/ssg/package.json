{
  "name": "ssg-react-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssg-react-example",
    "dev": "vite",
    "build:app": "vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && tsx scripts/ssg-build.ts",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/react": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "react": "~19.2.7",
    "react-dom": "~19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "7.3.6"
  }
}
