{
  "name": "ssg-angular-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssg-angular-example",
    "dev": "ng serve",
    "build:app": "ng build && tsx scripts/ssg-build.ts",
    "preview": "sirv dist/ssg-angular-example/browser --port 4210 --quiet",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@angular/common": "~22.0.6",
    "@angular/core": "~22.0.6",
    "@angular/platform-browser": "~22.0.6",
    "@angular/platform-server": "~22.0.6",
    "@angular/router": "~22.0.6",
    "@angular/ssr": "~22.0.6",
    "@real-router/angular": "workspace:^",
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "express": "5.1.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "~22.0.6",
    "@angular/cli": "~22.0.6",
    "@angular/compiler": "~22.0.6",
    "@angular/compiler-cli": "~22.0.6",
    "@playwright/test": "1.60.0",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "sirv-cli": "3.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
