{
  "name": "ssr-streaming-svelte-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssr-streaming-svelte-example",
    "dev": "tsx server/dev.ts",
    "build:app": "svelte-check && vite build --outDir dist/client && vite build --ssr src/entry-server.ts --outDir dist/server",
    "preview": "NODE_ENV=production tsx server/index.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/core": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "@real-router/svelte": "workspace:^",
    "express": "5.1.0",
    "svelte": "5.55.7"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "svelte-check": "4.3.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "7.3.2"
  }
}
