{
  "name": "ssr-mixed-svelte-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssr-mixed-svelte-example",
    "dev": "tsx server/dev.ts",
    "build:app": "svelte-check && vite build --outDir dist/client && vite build --ssr src/entry-server.ts --outDir dist/server",
    "preview": "NODE_ENV=production tsx server/index.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "@real-router/svelte": "workspace:^",
    "express": "5.1.0",
    "svelte": "~5.56.4"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "svelte-check": "4.7.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "7.3.6"
  }
}
