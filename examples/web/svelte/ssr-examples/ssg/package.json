{
  "name": "ssg-svelte-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm turbo run bundle --filter=...ssg-svelte-example",
    "dev": "vite",
    "build:app": "svelte-check && vite build && vite build --ssr src/entry-server.ts --outDir dist/server && tsx scripts/ssg-build.ts",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/core": "workspace:^",
    "@real-router/ssr-data-plugin": "workspace:^",
    "@real-router/svelte": "workspace:^",
    "svelte": "~5.56.4"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/node": "24.13.3",
    "svelte-check": "4.6.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "7.3.6"
  }
}
