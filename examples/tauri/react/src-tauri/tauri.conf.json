{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "real-router-tauri-browser-demo",
  "version": "0.0.0",
  "identifier": "com.real-router.tauri.browser",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "real-router — Tauri + browser-plugin",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
