{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"]
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "tests"]
}
