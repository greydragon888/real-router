{
  "name": "@real-router/svelte",
  "version": "0.16.6",
  "type": "module",
  "description": "Svelte 5 integration for Real-Router",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "svelte": "./dist/ssr.js",
      "default": "./dist/ssr.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/greydragon888/real-router",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "scripts": {
    "test": "vitest",
    "test:properties": "vitest run --config vitest.config.properties.mts",
    "test:stress": "vitest run --config vitest.config.stress.mts",
    "type-check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint --cache src/ tests/ --max-warnings 0",
    "lint:fix": "eslint --cache src/ tests/ --fix --max-warnings 0",
    "bundle": "svelte-package -i src -o dist && rimraf dist/dom-utils/CLAUDE.md"
  },
  "keywords": [
    "router",
    "html5",
    "history",
    "tree",
    "svelte",
    "svelte5",
    "runes",
    "reactive",
    "components",
    "real-router"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "sideEffects": false,
  "dependencies": {
    "@real-router/core": "workspace:^",
    "@real-router/route-utils": "workspace:^",
    "@real-router/sources": "workspace:^"
  },
  "devDependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@sveltejs/package": "2.5.8",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@testing-library/jest-dom": "~6.9.1",
    "@testing-library/svelte": "~5.4.2",
    "@testing-library/user-event": "~14.6.1",
    "eslint-plugin-svelte": "3.21.0",
    "rimraf": "6.1.3",
    "svelte": "~5.56.4",
    "svelte-check": "4.6.0",
    "svelte-eslint-parser": "1.8.0"
  },
  "peerDependencies": {
    "svelte": ">=5.7.0"
  }
}
