{
  "name": "@real-router/react",
  "version": "0.29.6",
  "type": "commonjs",
  "description": "React integration for Real-Router",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "typesVersions": {
    "*": {
      "legacy": [
        "./dist/cjs/legacy.d.ts"
      ],
      "ink": [
        "./dist/cjs/ink.d.ts"
      ],
      "ssr": [
        "./dist/cjs/ssr.d.ts"
      ],
      "legacy/ssr": [
        "./dist/cjs/legacy.ssr.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "react-server": {
        "@real-router/internal-source": "./src/index.react-server.ts",
        "types": {
          "import": "./dist/esm/index.react-server.d.mts",
          "require": "./dist/cjs/index.react-server.d.ts"
        },
        "import": "./dist/esm/index.react-server.mjs",
        "require": "./dist/cjs/index.react-server.js"
      },
      "@real-router/internal-source": "./src/index.ts",
      "types": {
        "import": "./dist/esm/index.d.mts",
        "require": "./dist/cjs/index.d.ts"
      },
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./legacy": {
      "@real-router/internal-source": "./src/legacy.ts",
      "types": {
        "import": "./dist/esm/legacy.d.mts",
        "require": "./dist/cjs/legacy.d.ts"
      },
      "import": "./dist/esm/legacy.mjs",
      "require": "./dist/cjs/legacy.js"
    },
    "./ink": {
      "@real-router/internal-source": "./src/ink.ts",
      "types": {
        "import": "./dist/esm/ink.d.mts",
        "require": "./dist/cjs/ink.d.ts"
      },
      "import": "./dist/esm/ink.mjs",
      "require": "./dist/cjs/ink.js"
    },
    "./ssr": {
      "react-server": {
        "@real-router/internal-source": "./src/ssr.react-server.ts",
        "types": {
          "import": "./dist/esm/ssr.react-server.d.mts",
          "require": "./dist/cjs/ssr.react-server.d.ts"
        },
        "import": "./dist/esm/ssr.react-server.mjs",
        "require": "./dist/cjs/ssr.react-server.js"
      },
      "@real-router/internal-source": "./src/ssr.ts",
      "types": {
        "import": "./dist/esm/ssr.d.mts",
        "require": "./dist/cjs/ssr.d.ts"
      },
      "import": "./dist/esm/ssr.mjs",
      "require": "./dist/cjs/ssr.js"
    },
    "./legacy/ssr": {
      "@real-router/internal-source": "./src/legacy.ssr.ts",
      "types": {
        "import": "./dist/esm/legacy.ssr.d.mts",
        "require": "./dist/cjs/legacy.ssr.d.ts"
      },
      "import": "./dist/esm/legacy.ssr.mjs",
      "require": "./dist/cjs/legacy.ssr.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/greydragon888/real-router",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "scripts": {
    "test": "vitest",
    "test:properties": "vitest run --config vitest.config.properties.mts",
    "test:stress": "vitest run --config vitest.config.stress.mts",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --ext .ts,.tsx src/ tests/ --max-warnings 0",
    "lint:fix": "eslint --cache --ext .ts,.tsx src/ tests/ --fix --max-warnings 0",
    "bundle": "tsdown --config-loader unrun"
  },
  "keywords": [
    "router",
    "html5",
    "history",
    "tree",
    "react",
    "hooks",
    "components",
    "functional",
    "real-router"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "sideEffects": false,
  "dependencies": {
    "@real-router/core": "workspace:^",
    "@real-router/route-utils": "workspace:^",
    "@real-router/sources": "workspace:^"
  },
  "devDependencies": {
    "@real-router/browser-plugin": "workspace:^",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/jest-dom": "~6.9.1",
    "@testing-library/react": "~16.3.2",
    "@testing-library/user-event": "~14.6.1",
    "ink": "7.1.0",
    "ink-testing-library": "4.0.0",
    "vitest-react-profiler": "1.12.0"
  },
  "peerDependencies": {
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0",
    "ink": ">=7.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    }
  }
}
