{
  "name": "@real-router/core",
  "version": "0.79.0",
  "type": "commonjs",
  "description": "A simple, powerful, view-agnostic, modular and extensible router",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "typesVersions": {
    "*": {
      "types": [
        "./dist/cjs/types.d.ts"
      ],
      "api": [
        "./dist/cjs/api.d.ts"
      ],
      "utils": [
        "./dist/cjs/utils.d.ts"
      ],
      "validation": [
        "./dist/cjs/validation.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "@real-router/internal-source": "./src/index.ts",
      "types": {
        "import": "./dist/esm/index.d.mts",
        "require": "./dist/cjs/index.d.ts"
      },
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./types": {
      "@real-router/internal-source": "./src/types/index.ts",
      "types": {
        "import": "./dist/esm/types.d.mts",
        "require": "./dist/cjs/types.d.ts"
      },
      "import": "./dist/esm/types.mjs",
      "require": "./dist/cjs/types.js"
    },
    "./api": {
      "@real-router/internal-source": "./src/api/index.ts",
      "types": {
        "import": "./dist/esm/api.d.mts",
        "require": "./dist/cjs/api.d.ts"
      },
      "import": "./dist/esm/api.mjs",
      "require": "./dist/cjs/api.js"
    },
    "./utils": {
      "@real-router/internal-source": "./src/utils/index.ts",
      "types": {
        "import": "./dist/esm/utils.d.mts",
        "require": "./dist/cjs/utils.d.ts"
      },
      "import": "./dist/esm/utils.mjs",
      "require": "./dist/cjs/utils.js"
    },
    "./validation": {
      "@real-router/internal-source": "./src/validation.ts",
      "types": {
        "import": "./dist/esm/validation.d.mts",
        "require": "./dist/cjs/validation.d.ts"
      },
      "import": "./dist/esm/validation.mjs",
      "require": "./dist/cjs/validation.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "keywords": [
    "router",
    "routing",
    "html5",
    "functional",
    "reactive",
    "universal",
    "isomorphic",
    "real-router"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "homepage": "https://github.com/greydragon888/real-router",
  "scripts": {
    "test": "vitest run",
    "test:properties": "vitest run --config vitest.config.properties.mts",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run --config vitest.config.stress.mts",
    "test:mutation": "stryker run",
    "test:mutation:report": "open reports/mutation-report.html",
    "bench": "tsx tests/benchmarks/run.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --ext .ts src/ tests/ --max-warnings 0",
    "lint:fix": "eslint --cache --ext .ts src/ tests/ --fix --max-warnings 0",
    "bundle": "tsdown --config-loader unrun"
  },
  "sideEffects": false
}
