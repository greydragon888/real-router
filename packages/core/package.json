{
  "name": "@real-router/core",
  "version": "0.40.1",
  "type": "commonjs",
  "description": "A simple, powerful, view-agnostic, modular and extensible router",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "typesVersions": {
    "*": {
      "api": [
        "./dist/cjs/api.d.ts"
      ],
      "utils": [
        "./dist/cjs/utils.d.ts"
      ],
      "validation": [
        "./dist/cjs/validation.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": {
        "import": "./dist/esm/index.d.mts",
        "require": "./dist/cjs/index.d.ts"
      },
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./api": {
      "development": "./src/api/index.ts",
      "types": {
        "import": "./dist/esm/api.d.mts",
        "require": "./dist/cjs/api.d.ts"
      },
      "import": "./dist/esm/api.mjs",
      "require": "./dist/cjs/api.js"
    },
    "./utils": {
      "development": "./src/utils/index.ts",
      "types": {
        "import": "./dist/esm/utils.d.mts",
        "require": "./dist/cjs/utils.d.ts"
      },
      "import": "./dist/esm/utils.mjs",
      "require": "./dist/cjs/utils.js"
    },
    "./validation": {
      "development": "./src/validation.ts",
      "types": {
        "import": "./dist/esm/validation.d.mts",
        "require": "./dist/cjs/validation.d.ts"
      },
      "import": "./dist/esm/validation.mjs",
      "require": "./dist/cjs/validation.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greydragon888/real-router.git"
  },
  "keywords": [
    "router",
    "routing",
    "html5",
    "functional",
    "reactive",
    "universal",
    "isomorphic",
    "real-router"
  ],
  "author": {
    "name": "Oleg Ivanov",
    "email": "greydragon888@gmail.com",
    "url": "https://github.com/greydragon888"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/greydragon888/real-router/issues"
  },
  "homepage": "https://github.com/greydragon888/real-router",
  "scripts": {
    "build": "tsup",
    "test": "vitest run functional/",
    "test:properties": "vitest run --config vitest.config.properties.mts",
    "test:coverage": "vitest run functional/ --coverage",
    "test:stress": "vitest run --config vitest.config.stress.mts",
    "test:mutation": "stryker run",
    "bench": "NODE_OPTIONS='--expose-gc --max-old-space-size=4096' npx tsx tests/benchmarks/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --ext .ts src/ tests/ --fix --max-warnings 0",
    "lint:package": "publint",
    "lint:types": "attw --pack .",
    "build:dist-only": "tsup"
  },
  "sideEffects": [
    "./dist/esm/chunk-*.mjs"
  ],
  "dependencies": {
    "@real-router/fsm": "workspace:^",
    "@real-router/logger": "workspace:^",
    "@real-router/types": "workspace:^"
  },
  "devDependencies": {
    "event-emitter": "workspace:^",
    "route-tree": "workspace:^"
  }
}
