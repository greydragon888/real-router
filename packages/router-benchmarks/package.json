{
  "name": "router-benchmarks",
  "version": "0.3.42",
  "private": true,
  "description": "Benchmark tests for @real-router/core",
  "scripts": {
    "prebench": "pnpm --filter @real-router/core... build",
    "bench": "BENCH_ROUTER=real-router NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx src/index.ts",
    "bench:router5": "BENCH_ROUTER=router5 NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx src/index.ts",
    "bench:router6": "BENCH_ROUTER=router6 NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx src/index.ts",
    "bench:current": "pnpm prebench && BENCH_ROUTER=real-router NODE_OPTIONS='--expose-gc --max-old-space-size=8192' npx tsx src/index.ts",
    "bench:client-nav:build:real-router": "vite build --config client-nav/real-router/react/vite.config.ts",
    "bench:client-nav:build:tanstack": "vite build --config client-nav/tanstack/react/vite.config.ts",
    "bench:client-nav:real-router": "pnpm bench:client-nav:build:real-router && NODE_ENV=production vitest bench --config client-nav/real-router/react/vite.config.ts client-nav/real-router/react/speed.bench.ts",
    "bench:client-nav:tanstack": "pnpm bench:client-nav:build:tanstack && NODE_ENV=production vitest bench --config client-nav/tanstack/react/vite.config.ts client-nav/tanstack/react/speed.bench.ts",
    "bench:client-nav:flame:real-router": "pnpm bench:client-nav:build:real-router && NODE_ENV=production node client-nav/real-router/react/speed.flame.ts",
    "bench:client-nav:flame:tanstack": "pnpm bench:client-nav:build:tanstack && NODE_ENV=production node client-nav/tanstack/react/speed.flame.ts",
    "cpu": "ps -Ao %cpu,comm -r | awk '$1 > 10 && !/webstorm/ && !/claude/ && !/WindowServer/ {print $2 \" (\" $1 \"%)\"}' | head -10",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache src/ --fix --max-warnings 0"
  },
  "dependencies": {
    "mitata": "1.0.34",
    "router5": "8.0.1",
    "router6": "1.0.2",
    "@real-router/core": "workspace:^",
    "@real-router/types": "workspace:^",
    "@real-router/react": "workspace:^",
    "@real-router/browser-plugin": "workspace:^",
    "@real-router/search-schema-plugin": "workspace:^",
    "@real-router/lifecycle-plugin": "workspace:^",
    "@tanstack/react-router": "1.168.10",
    "nanostores": "0.11.4",
    "@nanostores/react": "0.8.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@tanstack/router-core": "1.168.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "26.1.0",
    "vite": "7.2.0",
    "vitest": "4.1.0"
  }
}
